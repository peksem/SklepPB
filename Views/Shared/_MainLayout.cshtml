<!DOCTYPE html>
<html lang="en">
<head>
    <title> @ViewData["Title"] - Wypożyczalnia filmów </title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="~/css/main.css" rel="stylesheet" />
    <style>
        .fakeimg {
          height: 200px;
          background: #aaa;
        }
    </style>
</head>
<body>

    <div class="p-5 bg-primary text-white text-center">
        
    </div>

    @(await Component.InvokeAsync("Menu"))

    <div class="container mt-5">
        <div class="row">
            <div class="col-sm-8">
                @RenderBody()
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-dark text-white text-center shop-footer">
        <p>
            <a href="@Url.Action("FooterSites", "Home", new { name = "About" })">O mnie</a>
            <a href="@Url.Action("FooterSites", "Home", new { name = "Payment" })">Metody płatności</a>
            <a href="@Url.Action("FooterSites", "Home", new { name = "Terms" })">Regulamin</a>
            <a href="@Url.Action("FooterSites", "Home", new { name = "Contact" })">Kontakt</a>
        </p>
    </div>


    @RenderSection("scripts", false)
</body>
</html>

