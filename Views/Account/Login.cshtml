@model LoginViewModel

<h1>
	@ViewBag.message
</h1>


@using (Html.BeginForm("Login", "Account", FormMethod.Post))
{

	<div class="form-group">
		@Html.LabelFor(m => m.UserName, "Podaj login: ")
		@Html.TextBoxFor(m => m.UserName, new { @class = "form-control", @required = true })
		<p class="alert-warning">
			@Html.ValidationMessageFor(m => m.UserName)
		</p>
	</div>

	<div class="form-group">
		@Html.LabelFor(m => m.Password, "Podaj hasło: ")
		@Html.TextBoxFor(m => m.Password, new { @class = "form-control", type = "password", @required = true })
		<p class="alert-warning">
			@Html.ValidationMessageFor(m => m.Password)
		</p>
	</div>


	<div class="form-group">

		<button class="btn btn-primary" type="submit">Zaloguj</button>
	</div>
}